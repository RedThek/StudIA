<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.*?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="cm.enspm.studia.HelloController">
    <top>
        <Label text="Gestion scolaire secondaire bilingue / Bilingual Secondary School Management"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 12;" />
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="Élèves / Students">
                    <BorderPane>
                        <top>
                            <GridPane hgap="10" vgap="10">
                                <padding>
                                    <Insets bottom="10" left="10" right="10" top="10" />
                                </padding>
                                <Label text="Matricule:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                <TextField fx:id="matriculeField" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                                <Label text="Nom:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                <TextField fx:id="nomField" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                                <Label text="Prénom:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                <TextField fx:id="prenomField" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                                <Label text="Date de naissance:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                                <TextField fx:id="dateNaissanceField" GridPane.rowIndex="3" GridPane.columnIndex="1" />

                                <Label text="Lieu de naissance:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                                <TextField fx:id="lieuNaissanceField" GridPane.rowIndex="4" GridPane.columnIndex="1" />

                                <Label text="Sexe:" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                                <TextField fx:id="sexeField" GridPane.rowIndex="5" GridPane.columnIndex="1" />

                                <Label text="Nationalité:" GridPane.rowIndex="6" GridPane.columnIndex="0" />
                                <TextField fx:id="nationaliteField" GridPane.rowIndex="6" GridPane.columnIndex="1" />
                            </GridPane>
                        </top>
                        <center>
                            <TableView fx:id="studentsTable" prefHeight="360" />
                        </center>
                        <bottom>
                            <HBox spacing="12">
                                <padding>
                                    <Insets bottom="10" left="10" right="10" top="10" />
                                </padding>
                                <Button text="Ajouter / Add" onAction="#onCreateStudent" />
                                <Button text="Mettre à jour / Update" onAction="#onUpdateStudent" />
                                <Button text="Supprimer / Delete" onAction="#onDeleteStudent" />
                                <Button text="Effacer / Clear" onAction="#onClearForm" />
                            </HBox>
                        </bottom>
                    </BorderPane>
                </Tab>
                <Tab text="Bulletin / Report Card">
                    <VBox spacing="12">
                        <padding>
                            <Insets bottom="10" left="10" right="10" top="10" />
                        </padding>
                        <HBox spacing="10">
                            <Label text="Matricule :" />
                            <TextField fx:id="reportMatriculeField" promptText="ELV2024-001" />
                            <Button text="Charger / Load" onAction="#onLoadReport" />
                            <Button text="Générer PDF / Generate PDF" onAction="#onGeneratePdf" />
                        </HBox>
                        <TableView fx:id="reportTable" prefHeight="460" />
                    </VBox>
                </Tab>
            </tabs>
        </TabPane>
    </center>
    <bottom>
        <Label fx:id="statusLabel" style="-fx-padding: 10; -fx-background-color: #f4f4f4;" />
    </bottom>
</BorderPane>
